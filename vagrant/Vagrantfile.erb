# =============================================================================
# Vagrantfile.erb
# ERB template rendered by Deploy-Lab.ps1 -> New-Vagrantfile.
# DO NOT edit this file directly — edit config.yaml and re-run Deploy-Lab.ps1.
#
# PURPOSE: Bring VMs online and establish networking ONLY.
# All guest provisioning is performed by scripts/Provision-DomainController.ps1
# (and future scripts for other roles) via SSH after 'vagrant up' completes.
# =============================================================================

# -- Generated by Deploy-Lab.ps1 on <%= Time.now.strftime('%Y-%m-%d %H:%M') %> --
# Config: <%= @config_path %>

Vagrant.configure("2") do |config|

  # ── Communicator: SSH only ────────────────────────────────────────────────────
  # Vagrant uses SSH to verify the box is up. We do NOT use WinRM — all
  # provisioning is handled externally by the SSH orchestrator scripts.
  config.vm.guest        = :windows
  config.vm.communicator = "ssh"
  config.vm.boot_timeout = 1800  # 30 min overall boot window (first boot + Sysprep)

  # ── SSH credentials ───────────────────────────────────────────────────────────
  config.ssh.username   = "vagrant"
  config.ssh.password   = "vagrant"
  config.ssh.insert_key = false
  config.ssh.shell      = "powershell"
  config.ssh.extra_args = ["-o", "StrictHostKeyChecking=no", "-o", "UserKnownHostsFile=/dev/null"]

  # ── Disable default /vagrant synced folder (not needed for this lab) ─────────
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # ==========================================================================
  # QEMU HARDWARE QUIRKS (Matching the Packer Build)
  # These must exactly match the settings used in windows-sql.pkr.hcl or
  # Windows will BSOD with INACCESSIBLE_BOOT_DEVICE on first boot.
  # ==========================================================================
  config.vm.provider "qemu" do |qe|
    # Explicitly set qemu_dir to avoid vagrant-qemu defaulting to macOS path on Linux
    qe.qemu_dir = "/usr/share/qemu"

    # Machine Architecture: MUST match Packer build (pc = i440fx, NOT q35)
    qe.machine         = "pc"
    qe.arch            = "x86_64"
    qe.cpu             = "host"     # correct attr is 'cpu', not 'cpu_model'

    # Drivers: Windows native drivers only — no VirtIO out of the box
    qe.net_device      = "e1000e"
    qe.drive_interface = "ide"

    # Auto-correct SSH port collision
    qe.ssh_auto_correct = true

    # NOTE: extra_qemu_args is set per-machine below (includes -enable-kvm,
    # -display none, AND the socket NIC for inter-VM networking)
  end

<% @regions.each_with_index do |region, region_idx| %>
  # ============================================================================
  # Region: <%= region[:name] %> — Network: <%= region[:network] %>
  # Multicast port for inter-VM socket NIC: <%= 5000 + region_idx %>
  # ============================================================================
<% region[:nodes].each do |node| %>
  config.vm.define "<%= node[:hostname] %>", primary: <%= node.fetch(:primary, false) %> do |machine|
    machine.vm.box      = "<%= node[:box_name] %>"
    machine.vm.box_url  = "file://<%= node[:box_path] %>"

    # ── Per-VM QEMU overrides ─────────────────────────────────────────────────
    # - qe.ssh_port: unique host port for QEMU user-mode hostfwd
    # - qe.smp: vCPU count (correct attr; 'cpus' is silently ignored)
    # - extra_qemu_args: MUST include -enable-kvm/-display here because
    #   per-machine args REPLACE global args in vagrant-qemu's merge.
    #   Socket NIC provides inter-VM networking (all VMs in a region share
    #   multicast group 230.0.0.1:<%= 5000 + region_idx %> as a virtual switch).
    machine.vm.provider "qemu" do |qe|
      qe.smp      = "<%= node.fetch(:cpus, 2) %>"
      qe.memory   = "<%= node.fetch(:memory_mb, 2048) %>M"
      qe.ssh_port = <%= node[:ssh_port] %>
      qe.extra_qemu_args = [
        "-enable-kvm", "-display", "none",
        "-netdev", "socket,id=lab-net,mcast=230.0.0.1:<%= 5000 + region_idx %>",
        "-device", "e1000e,netdev=lab-net"
      ]
    end

    # Vagrant SSH port (for 'vagrant ssh' and health-check communication)
    machine.ssh.port = <%= node[:ssh_port] %>

    # ── Inter-VM network declaration ──────────────────────────────────────────
    # The QEMU socket NIC above handles actual inter-VM traffic.
    # This private_network declaration is kept for documentation / Virtualbox
    # compatibility — QEMU ignores it in favour of extra_qemu_args above.
    # The actual static IP is configured inside the guest by the SSH provisioner
    # script (scripts/Provision-DomainController.ps1 → Set-StaticIP.ps1).
    machine.vm.network "private_network",
      ip:           "<%= node[:static_ip] %>",
      netmask:      "<%= region[:netmask] %>",
      virtualbox__intnet: "<%= region[:name].downcase %>_net"

  end  # define <%= node[:hostname] %>
<% end %>
<% end %>

end
