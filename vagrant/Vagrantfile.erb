# =============================================================================
# Vagrantfile.erb
# ERB template rendered by Deploy-Lab.ps1 -> New-Vagrantfile.
# DO NOT edit this file directly — edit config.yaml and re-run Deploy-Lab.ps1.
# Variables injected by New-Vagrantfile are Ruby locals: @config, @nodes, etc.
# =============================================================================

# -- Generated by Deploy-Lab.ps1 on <%= Time.now.strftime('%Y-%m-%d %H:%M') %> --
# Config: <%= @config_path %>

Vagrant.configure("2") do |config|

  # ── Global SSH settings (OpenSSH baked into every Packer image) ─────────────
  config.vm.guest          = :windows
  config.vm.communicator   = "ssh"
  config.ssh.username      = "vagrant"
  config.ssh.password      = "vagrant"    # Box default; insert_key is off so password auth is used
  config.ssh.insert_key    = false        # Windows NTFS can't chmod 0600 authorized_keys
  config.ssh.shell         = "pwsh"       # Must match OpenSSH DefaultShell in HKLM registry
  config.vm.boot_timeout   = 600          # Windows boots slowly after Sysprep

  # ── Disable default /vagrant synced folder (not needed for this lab) ─────────
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # ==========================================================================
  # QEMU HARDWARE QUIRKS (Matching the Packer Build)
  # These must exactly match the settings used in windows-sql.pkr.hcl or
  # Windows will BSOD with INACCESSIBLE_BOOT_DEVICE on first boot.
  # ==========================================================================
  config.vm.provider "qemu" do |qe|
    # Explicitly set qemu_dir to avoid vagrant-qemu defaulting to macOS path on Linux
    qe.qemu_dir = "/usr/share/qemu"

    # Machine Architecture: MUST match Packer build (pc = i440fx, NOT q35)
    qe.machine         = "pc"
    qe.arch            = "x86_64"
    qe.cpu             = "host"     # NOTE: correct attr is 'cpu', not 'cpu_model'

    # Drivers: Windows native drivers only — no VirtIO out of the box
    qe.net_device      = "e1000e"
    qe.drive_interface = "ide"

    # Auto-correct SSH port if the default 50022 is already in use
    qe.ssh_auto_correct = true

    # Headless mode. Change to "-display gtk -vga std" for visual boot debugging.
    qe.extra_qemu_args = %w[-enable-kvm -display none]
  end

<% @regions.each do |region| %>
  # ============================================================================
  # Region: <%= region[:name] %> — Network: <%= region[:network] %>
  # ============================================================================
<% region[:nodes].each do |node| %>
  config.vm.define "<%= node[:hostname] %>", primary: <%= node.fetch(:primary, false) %> do |machine|
    machine.vm.hostname = "<%= node[:hostname] %>"
    machine.vm.box      = "<%= node[:box_name] %>"
    machine.vm.box_url  = "file://<%= node[:box_path] %>"

    # ── Per-VM QEMU overrides: size and unique SSH host port ─────────────────
    # qe.ssh_port tells vagrant-qemu which host port to use in QEMU's
    # user-mode hostfwd (e.g. hostfwd=tcp::50022-:22). Without this, ALL VMs
    # default to 50022 and the second VM fails with a port collision.
    # qe.smp is the correct attr for vCPU count (not cpus).
    machine.vm.provider "qemu" do |qe|
      qe.smp      = "<%= node.fetch(:cpus, 2) %>"
      qe.memory   = "<%= node.fetch(:memory_mb, 2048) %>M"
      qe.ssh_port = <%= node[:ssh_port] %>
    end

    # Vagrant also needs to know which host port to connect to for ssh/provision
    machine.ssh.port = <%= node[:ssh_port] %>

    # ── Static IP via private network (ignored by QEMU provider; Set-StaticIP.ps1
    #    configures the NIC inside the guest) ─────────────────────────────────
    machine.vm.network "private_network",
      ip:           "<%= node[:static_ip] %>",
      netmask:      "<%= region[:netmask] %>",
      virtualbox__intnet: "<%= region[:name].downcase %>_net"

    # ── Provisioning order ───────────────────────────────────────────────────
    # 1. Set static IP (idempotent — assigns IP/gateway/DNS on the non-NAT NIC)
    machine.vm.provision "Set-StaticIP", type: "shell",
      path:              "provisioners/Set-StaticIP.ps1",
      privileged:        true,
      powershell_elevated_interactive: false,
      args:              [
        "<%= node[:static_ip] %>",
        "<%= region[:prefix_length] %>",
        "<%= region[:gateway] %>",
        "<%= node[:dns_server] %>"
      ]

    # 2. Rename computer (triggers reboot)
    machine.vm.provision "Set-Hostname", type: "shell",
      path:    "provisioners/Set-Hostname.ps1",
      privileged: true,
      args:    ["<%= node[:hostname] %>"],
      reboot:  true

<% if node[:role] == 'DomainController' %>
    # 2b. Disable SQL Server service (box has SQL pre-staged; DC doesn't need it)
    machine.vm.provision "Disable-SqlServer", type: "shell",
      path:       "provisioners/Disable-SqlServer.ps1",
      privileged: true

    # 3a. Promote to Domain Controller
    machine.vm.provision "Install-ADDS", type: "shell",
      path:    "provisioners/Install-ADDSForest.ps1",
      privileged: true,
      args:    [
        "<%= @domain_name %>",
        "<%= @admin_password %>",
        "<%= node[:dc_mode] %>"  # "Forest" or "Replica"
      ],
      reboot:  true

    # 3b. Create lab admin account (only on the first/forest DC)
<% if node[:dc_mode] == 'Forest' %>
    machine.vm.provision "New-LabAdmin", type: "shell",
      path:    "provisioners/New-LabAdminAccount.ps1",
      privileged: true,
      args:    [
        "<%= @domain_name %>",
        "<%= @admin_user %>",
        "<%= @admin_password %>"
      ]
<% end %>
<% else %>
    # 3a. Wait for DC and join domain
    machine.vm.provision "Join-Domain", type: "shell",
      path:    "provisioners/Join-Domain.ps1",
      privileged: true,
      args:    [
        "<%= @domain_name %>",
        "<%= @forest_dc_ip %>",
        "<%= @admin_user %>",
        "<%= @admin_password %>"
      ],
      reboot:  true

    # 3b. SQL Server CompleteImage
    machine.vm.provision "Complete-SqlImage", type: "shell",
      path:    "provisioners/Complete-SqlImage.ps1",
      privileged: true,
      args:    [
        "<%= @domain_name %>",
        "<%= @admin_user %>",
        "<%= @admin_password %>"
      ]

    # 3c. dbatools post-configuration
    machine.vm.provision "Configure-SqlServer", type: "shell",
      path:    "provisioners/Configure-SqlServer.ps1",
      privileged: true,
      args:    [
        "<%= @admin_password %>"
      ]
<% end %>

  end  # define <%= node[:hostname] %>
<% end %>
<% end %>

end
