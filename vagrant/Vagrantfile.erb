# =============================================================================
# Vagrantfile.erb
# ERB template rendered by Deploy-Lab.ps1 -> New-Vagrantfile.
# DO NOT edit this file directly — edit config.yaml and re-run Deploy-Lab.ps1.
# Variables injected by New-Vagrantfile are Ruby locals: @config, @nodes, etc.
# =============================================================================

# -- Generated by Deploy-Lab.ps1 on <%= Time.now.strftime('%Y-%m-%d %H:%M') %> --
# Config: <%= @config_path %>

Vagrant.configure("2") do |config|

  # ── Global SSH settings (OpenSSH baked into every Packer image) ─────────────
  config.vm.guest          = :windows
  config.vm.communicator   = "ssh"
  config.ssh.username      = "vagrant"
  config.ssh.insert_key    = false   # Windows doesn't support POSIX chmod for key insertion
  config.ssh.shell         = "pwsh -NoProfile -NonInteractive -Command"
  config.vm.boot_timeout   = 600     # Windows boots slowly after Sysprep

  # ── Disable default /vagrant synced folder (not needed for this lab) ─────────
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # ── Load the active provider library ─────────────────────────────────────────
  require_relative "<%= @provider_lib %>"   # e.g. lib/provider_qemu

<% @regions.each do |region| %>
  # ============================================================================
  # Region: <%= region[:name] %> — Network: <%= region[:network] %>
  # ============================================================================
<% region[:nodes].each do |node| %>
  config.vm.define "<%= node[:hostname] %>", primary: <%= node.fetch(:primary, false) %> do |machine|
    machine.vm.hostname = "<%= node[:hostname] %>"
    machine.vm.box      = "<%= node[:box_name] %>"
    machine.vm.box_url  = "file://<%= node[:box_path] %>"

    # ── Static IP via private network ────────────────────────────────────────
    machine.vm.network "private_network",
      ip:           "<%= node[:static_ip] %>",
      netmask:      "<%= region[:netmask] %>",
      virtualbox__intnet: "<%= region[:name].downcase %>_net"

    # ── Provider-specific configuration ──────────────────────────────────────
    configure_provider(machine, {
      cpus:      <%= node.fetch(:cpus, 2) %>,
      memory_mb: <%= node.fetch(:memory_mb, 2048) %>,
      name:      "<%= node[:hostname] %>"
    })

    # ── Provisioning order ───────────────────────────────────────────────────
    # 1. Set static IP (idempotent — WinRM may still be using NAT at this point)
    machine.vm.provision "Set-StaticIP", type: "shell",
      path:              "../provisioners/Set-StaticIP.ps1",
      privileged:        true,
      powershell_elevated_interactive: false,
      args:              [
        "<%= node[:static_ip] %>",
        "<%= region[:prefix_length] %>",
        "<%= region[:gateway] %>",
        "<%= node[:dns_server] %>"
      ]

    # 2. Rename computer (triggers reboot)
    machine.vm.provision "Set-Hostname", type: "shell",
      path:    "../provisioners/Set-Hostname.ps1",
      privileged: true,
      args:    ["<%= node[:hostname] %>"],
      reboot:  true

<% if node[:role] == 'DomainController' %>
    # 3a. Promote to Domain Controller
    machine.vm.provision "Install-ADDS", type: "shell",
      path:    "../provisioners/Install-ADDSForest.ps1",
      privileged: true,
      args:    [
        "<%= @domain_name %>",
        "<%= @admin_password %>",
        "<%= node[:dc_mode] %>"  # "Forest" or "Replica"
      ],
      reboot:  true

    # 3b. Create lab admin account (only on the first/forest DC)
<% if node[:dc_mode] == 'Forest' %>
    machine.vm.provision "New-LabAdmin", type: "shell",
      path:    "../provisioners/New-LabAdminAccount.ps1",
      privileged: true,
      args:    [
        "<%= @domain_name %>",
        "<%= @admin_user %>",
        "<%= @admin_password %>"
      ]
<% end %>
<% else %>
    # 3a. Wait for DC and join domain
    machine.vm.provision "Join-Domain", type: "shell",
      path:    "../provisioners/Join-Domain.ps1",
      privileged: true,
      args:    [
        "<%= @domain_name %>",
        "<%= @forest_dc_ip %>",
        "<%= @admin_user %>",
        "<%= @admin_password %>"
      ],
      reboot:  true

    # 3b. SQL Server CompleteImage
    machine.vm.provision "Complete-SqlImage", type: "shell",
      path:    "../provisioners/Complete-SqlImage.ps1",
      privileged: true,
      args:    [
        "<%= @domain_name %>",
        "<%= @admin_user %>",
        "<%= @admin_password %>"
      ]

    # 3c. dbatools post-configuration
    machine.vm.provision "Configure-SqlServer", type: "shell",
      path:    "../provisioners/Configure-SqlServer.ps1",
      privileged: true,
      args:    [
        "<%= @admin_password %>"
      ]
<% end %>

  end  # define <%= node[:hostname] %>
<% end %>
<% end %>

end
