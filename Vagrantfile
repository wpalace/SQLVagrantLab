    # - qe.ssh_port: unique host port for QEMU user-mode hostfwd
    # - qe.smp: vCPU count (correct attr; 'cpus' is silently ignored)
    # - extra_qemu_args: MUST include -enable-kvm/-display here because
    #   per-machine args REPLACE global args in vagrant-qemu's merge.
    #   Socket NIC provides inter-VM networking (all VMs in a region share
    #   multicast group 230.0.0.1:5000 as a virtual switch).
    machine.vm.provider "qemu" do |qe|
      qe.smp      = "4"
      qe.memory   = "4096M"
      qe.ssh_port = 50023
      # vagrant-qemu automatically adds WinRM hostfwd rules (port 5985 + 5986)
